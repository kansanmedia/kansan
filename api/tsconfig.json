{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "outDir": ".vercel/output",
    "rootDir": "../",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["**/*.ts", "../src/server/**/*.ts"],
  "exclude": ["../node_modules", "../dist"]
}
